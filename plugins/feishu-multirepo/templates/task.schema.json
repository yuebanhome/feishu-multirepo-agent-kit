{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Feishu Multi-Repo Task",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "primary_repo",
    "allowed_paths",
    "acceptance_criteria",
    "verification"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]+-[0-9]+$"
    },
    "status": {
      "enum": [
        "draft",
        "ready",
        "claimed",
        "in_progress",
        "blocked",
        "review",
        "done",
        "released"
      ]
    },
    "owner_type": {
      "enum": [
        "human",
        "agent",
        "none"
      ]
    },
    "owner": {
      "type": "string"
    },
    "primary_repo": {
      "type": "string"
    },
    "related_repos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "codegraph_seeds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "string"
    },
    "pr_url": {
      "type": "string"
    }
  }
}